{
  "manifest_version": 3,
  "name": "Trading Auto Analyzer",
  "version": "2.1.0",
  "description": "Détecte symbole/TF/prix depuis TradingView et envoie au backend trading",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "windows",
    "alarms"
  ],
  "host_permissions": [
    "https://*.tradingview.com/*",
    "http://127.0.0.1:4000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Trading Auto Analyzer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tradingview.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
